---
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";

interface StringTitleProp {
  pageTitle: string;
  pageDesc?: string;
}

interface ArrayTitleProp {
  pageTitle: [string, string];
  titleTransition: string;
  pageDesc?: string;
}

export type Props = StringTitleProp | ArrayTitleProp;

const { props } = Astro;

const backUrl = SITE.showBackButton ? Astro.url.pathname : "/";
---

<Breadcrumb />
<main
  data-backUrl={backUrl}
  id="main-content"
  class="mx-auto w-full max-w-app px-4 pb-4"
>
  {
    "titleTransition" in props ? (
      <h1 class="display-title max-w-[16ch] text-[2.75rem] leading-[1.02] font-semibold tracking-[-0.035em] sm:text-[3.25rem]">
        {props.pageTitle[0]}
        <span transition:name={props.titleTransition}>
          {props.pageTitle[1]}
        </span>
      </h1>
    ) : (
      <h1 class="display-title max-w-[16ch] text-[2.75rem] leading-[1.02] font-semibold tracking-[-0.035em] sm:text-[3.25rem]">{props.pageTitle}</h1>
    )
  }
  <p class="mt-3 mb-8 max-w-[60ch] text-[1.0625rem] leading-8 text-muted">{props.pageDesc}</p>
  <slot />
</main>

<script>
  document.addEventListener("astro:page-load", () => {
    const mainContent: HTMLElement | null =
      document.querySelector("#main-content");
    const backUrl = mainContent?.dataset?.backurl;
    if (backUrl) {
      sessionStorage.setItem("backUrl", backUrl);
    }
  });
</script>
